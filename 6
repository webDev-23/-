package view;

import model.Task;
import model.TaskStatus;

import java.util.List;
import java.util.Scanner;

public class TaskView {
    private Scanner scanner;

    public TaskView() {
        this.scanner = new Scanner(System.in);
    }

    public void showMenu() {
        System.out.println("\n" + "=".repeat(60));
        System.out.println("          📋 МЕНЕДЖЕР ЗАДАЧ 📋");
        System.out.println("=".repeat(60));
        System.out.println("1. ➕ Добавить задачу");
        System.out.println("2. 📋 Показать все задачи");
        System.out.println("3. ✏️  Обновить задачу");
        System.out.println("4. 🗑️  Удалить задачу");
        System.out.println("5. 🔍 Фильтровать задачи");
        System.out.println("6. ↩️  Отменить последнее действие");
        System.out.println("7. 📊 Статистика");
        System.out.println("8. 📜 История действий");
        System.out.println("0. 🚪 Выход");
        System.out.println("-".repeat(60));
    }

    public void showFilterMenu() {
        System.out.println("\n--- Типы фильтрации ---");
        System.out.println("1. По статусу");
        System.out.println("2. По приоритету");
        System.out.println("3. По ключевому слову");
        System.out.println("4. По диапазону дат");
        System.out.println("5. Комплексная фильтрация");
        System.out.println("0. Назад");
        System.out.println("-".repeat(40));
    }

    public String getStringInput(String prompt) {
        System.out.print(prompt);
        return scanner.nextLine().trim();
    }

    public int getIntInput(String prompt, int min, int max) {
        while (true) {
            try {
                System.out.print(prompt);
                int value = Integer.parseInt(scanner.nextLine().trim());
                if (value >= min && value <= max) {
                    return value;
                }
                System.out.println("⚠️  Пожалуйста, введите число от " + min + " до " + max);
            } catch (NumberFormatException e) {
                System.out.println("⚠️  Пожалуйста, введите корректное число.");
            }
        }
    }

    public Integer getOptionalIntInput(String prompt) {
        System.out.print(prompt);
        String input = scanner.nextLine().trim();
        if (input.isEmpty()) {
            return null;
        }
        try {
            int value = Integer.parseInt(input);
            if (value >= 1 && value <= 5) {
                return value;
            }
            System.out.println("⚠️  Приоритет должен быть от 1 до 5. Использовано текущее значение.");
            return null;
        } catch (NumberFormatException e) {
            System.out.println("⚠️  Некорректный ввод. Использовано текущее значение.");
            return null;
        }
    }

    public TaskStatus getStatusInput(String prompt) {
        while (true) {
            System.out.print(prompt);
            String input = scanner.nextLine().trim();
            if (input.isEmpty()) {
                System.out.println("⚠️  Статус не может быть пустым.");
                continue;
            }
            TaskStatus status = TaskStatus.fromString(input);
            if (status != null) {
                return status;
            }
            System.out.println("⚠️  Неверный статус. Допустимые значения: Новая, В процессе, Завершена, Отменена");
        }
    }

    public TaskStatus getOptionalStatusInput(String prompt) {
        System.out.print(prompt);
        String input = scanner.nextLine().trim();
        if (input.isEmpty()) {
            return null;
        }
        return TaskStatus.fromString(input);
    }

    public void showMessage(String message) {
        System.out.println(message);
    }

    public void showError(String error) {
        System.out.println("❌ " + error);
    }

    public void showTaskDetails(Task task) {
        System.out.println("\n📌 Информация о задаче:");
        System.out.println("-".repeat(50));
        System.out.println(task);
        System.out.println("-".repeat(50));
    }

    public void showAllTasks(List<Task> tasks) {
        System.out.println("\n📋 Список задач (" + tasks.size() + "):");
        System.out.println("=".repeat(60));
        for (Task task : tasks) {
            System.out.println(task.toShortString());
        }
        System.out.println("=".repeat(60));
    }
}
